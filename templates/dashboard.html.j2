<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>SSU Topology Analysis Dashboard</title>
  <script src="https://cdn.plot.ly/plotly-2.35.2.min.js"></script>
  <style>
    :root {
      --bg: #000000;
      --bg-soft: #06080d;
      --card: #0b0f17;
      --card-soft: #101624;
      --ink: #e8f4ff;
      --muted: #8d98ab;
      --line: rgba(86, 166, 255, 0.16);
      --cyan: #56a6ff;
      --emerald: #34d399;
      --amber: #ffbe5c;
      --rose: #ff8d6a;
      --shadow: 0 24px 60px rgba(0, 0, 0, 0.52);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      background:
        radial-gradient(circle at top left, rgba(86, 166, 255, 0.14), transparent 24%),
        radial-gradient(circle at 82% 12%, rgba(255, 190, 92, 0.07), transparent 22%),
        linear-gradient(180deg, #000000, var(--bg));
      color: var(--ink);
      font-family: "Space Grotesk", "Segoe UI", sans-serif;
      min-height: 100vh;
      padding: 18px 16px 48px;
    }

    .container {
      max-width: 1520px;
      margin: 0 auto;
    }

    .hero {
      background:
        linear-gradient(135deg, rgba(8, 12, 20, 0.98), rgba(13, 19, 31, 0.96)),
        radial-gradient(circle at top right, rgba(86, 166, 255, 0.10), transparent 28%);
      border: 1px solid var(--line);
      border-radius: 24px;
      padding: 16px 18px;
      box-shadow: var(--shadow);
      margin-bottom: 16px;
    }

    .hero h1 {
      margin: 0;
      font-size: clamp(24px, 3.4vw, 34px);
      letter-spacing: 0.3px;
    }

    .hero p {
      margin: 8px 0 0;
      font-size: 13px;
      line-height: 1.55;
      color: var(--muted);
      max-width: 1120px;
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .topology-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 16px;
    }

    .tab-button {
      appearance: none;
      border: 1px solid rgba(86, 166, 255, 0.22);
      background: rgba(8, 12, 20, 0.92);
      color: var(--ink);
      padding: 10px 14px;
      border-radius: 999px;
      font: inherit;
      font-size: 12px;
      letter-spacing: 0.24px;
      cursor: pointer;
      transition: background 120ms ease, border-color 120ms ease, transform 120ms ease;
    }

    .tab-button:hover {
      border-color: rgba(86, 166, 255, 0.42);
      box-shadow: 0 0 0 1px rgba(86, 166, 255, 0.10), 0 10px 24px rgba(0, 0, 0, 0.36);
      transform: translateY(-1px);
    }

    .tab-button.is-active {
      background: linear-gradient(135deg, rgba(86, 166, 255, 0.16), rgba(10, 15, 24, 0.98));
      border-color: rgba(86, 166, 255, 0.54);
      box-shadow: inset 0 0 24px rgba(86, 166, 255, 0.08), 0 10px 28px rgba(0, 0, 0, 0.34);
      color: #f2fbff;
    }

    .plot-card {
      background:
        linear-gradient(180deg, rgba(10, 14, 22, 0.98), rgba(5, 7, 11, 0.99)),
        radial-gradient(circle at top right, rgba(86, 166, 255, 0.05), transparent 28%);
      border: 1px solid var(--line);
      border-radius: 24px;
      box-shadow: var(--shadow);
      overflow: hidden;
      min-width: 0;
    }

    .plot-card-dark {
      background:
        linear-gradient(180deg, rgba(9, 13, 20, 0.98), rgba(4, 6, 10, 0.99)),
        radial-gradient(circle at top left, rgba(86, 166, 255, 0.04), transparent 30%);
    }

    .plot-card-head {
      padding: 18px 20px 10px;
      border-bottom: 1px solid rgba(148, 163, 184, 0.1);
    }

    .plot-card-head h2 {
      margin: 0;
      font-size: 26px;
    }

    .eyebrow {
      margin-top: 6px;
      color: var(--muted);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.34px;
    }

    .plot-shell {
      padding: 12px 12px 4px;
    }

    .plot-shell h3,
    .detail-pane h3 {
      margin: 0 0 10px;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 0.42px;
      color: var(--cyan);
    }

    .plot-frame {
      border: 1px solid rgba(86, 166, 255, 0.16);
      border-radius: 18px;
      background:
        linear-gradient(180deg, rgba(0, 0, 0, 0.98), rgba(4, 6, 10, 0.98));
      padding: 7px;
      overflow: hidden;
      min-width: 0;
    }

    .plot-frame > div,
    .plot-frame .js-plotly-plot,
    .plot-frame .plotly,
    .plot-frame .plot-container {
      width: 100% !important;
      min-width: 0;
    }

    .plot-caption {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 8px;
      margin-top: 10px;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.45;
    }

    .plot-caption span {
      display: block;
      padding: 7px 10px;
      border-radius: 12px;
      border: 1px solid rgba(86, 166, 255, 0.10);
      background: rgba(7, 10, 16, 0.76);
    }

    .traffic-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin-top: 12px;
      align-items: start;
    }

    .traffic-panel {
      display: grid;
      gap: 8px;
      min-width: 0;
    }

    .traffic-panel .plot-frame {
      padding: 6px;
    }

    .detail-pane {
      display: grid;
      gap: 12px;
      padding: 6px 12px 14px;
      align-items: start;
    }

    .detail-top-grid {
      display: grid;
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.75fr);
      gap: 12px;
      align-items: stretch;
    }

    .detail-top-grid > .section {
      height: 100%;
    }

    .section {
      border: 1px solid rgba(86, 166, 255, 0.10);
      border-radius: 18px;
      padding: 11px;
      background: rgba(7, 10, 16, 0.82);
    }

    .metrics-grid,
    .kv-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(130px, 1fr));
      gap: 8px;
    }

    .metric,
    .kv {
      border-radius: 14px;
      padding: 8px 10px;
      background: rgba(0, 0, 0, 0.88);
      border: 1px solid rgba(86, 166, 255, 0.08);
    }

    .metric .k,
    .kv .k {
      display: block;
      font-size: 9.5px;
      text-transform: uppercase;
      letter-spacing: 0.34px;
      color: var(--muted);
    }

    .metric .v,
    .kv .v {
      display: block;
      margin-top: 2px;
      line-height: 1.32;
      font-weight: 600;
    }

    .stack {
      display: grid;
      gap: 8px;
    }

    .workload-panel,
    .compact-table-panel {
      border-radius: 16px;
      padding: 10px;
      border: 1px solid rgba(86, 166, 255, 0.08);
      background: rgba(0, 0, 0, 0.84);
    }

    .workload-panel h4,
    .compact-table-panel h4 {
      margin: 0 0 8px;
      color: var(--amber);
      font-size: 13px;
    }

    .compact-table-wrap {
      overflow-x: auto;
      padding-bottom: 2px;
    }

    .compact-table {
      width: max-content;
      min-width: 100%;
      border-collapse: collapse;
      font-size: 11px;
      line-height: 1.35;
    }

    .compact-table th,
    .compact-table td {
      padding: 7px 8px;
      border-bottom: 1px solid rgba(148, 163, 184, 0.1);
      text-align: right;
      white-space: nowrap;
    }

    .compact-table th:first-child,
    .compact-table td:first-child {
      text-align: left;
    }

    .compact-table th {
      color: var(--muted);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.32px;
    }

    .small-notes,
    .small-notes li {
      color: var(--muted);
      font-size: 11.5px;
      line-height: 1.45;
    }

    ul {
      margin: 0;
      padding-left: 18px;
    }

    .interaction-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 8px;
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid rgba(86, 166, 255, 0.24);
      background: rgba(86, 166, 255, 0.08);
      color: #d9ecff;
      font-size: 11px;
      letter-spacing: 0.2px;
    }

    .details-panel {
      border: 1px solid rgba(86, 166, 255, 0.08);
      border-radius: 16px;
      background: rgba(0, 0, 0, 0.72);
      overflow: hidden;
    }

    .details-panel > summary {
      cursor: pointer;
      list-style: none;
      padding: 12px 14px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.18px;
    }

    .details-panel > summary::-webkit-details-marker {
      display: none;
    }

    .details-panel > summary::after {
      content: "+";
      float: right;
      color: var(--cyan);
      font-size: 16px;
      line-height: 1;
    }

    .details-panel[open] > summary::after {
      content: "-";
    }

    .details-body {
      display: grid;
      gap: 12px;
      padding: 0 12px 12px;
    }

    .topology-panel[hidden] {
      display: none !important;
    }

    .comparison-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }

    @media (max-width: 1280px) {
      .detail-top-grid { grid-template-columns: 1fr; }
      .comparison-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 1100px) {
      .traffic-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 720px) {
      body { padding: 12px 10px 34px; }
      .plot-card-head { padding: 14px 14px 8px; }
      .plot-shell { padding: 12px 12px 4px; }
      .detail-pane { padding: 8px 12px 14px; }
      .metrics-grid, .kv-grid { grid-template-columns: 1fr; }
      .topology-tabs { gap: 8px; }
      .tab-button { width: 100%; justify-content: center; }
    }
  </style>
</head>
<body>
  <div class="container">
    <section class="hero">
      <h1>SSU-Centric Topology Analysis Dashboard</h1>
      <p>Use the tabs to switch topologies. Hover any traffic link to inspect bidirectional carried rate, utilization, and offered volume.</p>
    </section>

    <section class="grid">
      <section class="plot-card plot-card-dark">
        <div class="plot-card-head">
          <h2>Topology Switcher</h2>
          <div class="topology-tabs" role="tablist" aria-label="Topology switcher">
            {% for r in results %}
            <button
              type="button"
              class="tab-button{% if loop.first %} is-active{% endif %}"
              data-topology-tab
              data-target="topology-panel-{{ loop.index0 }}"
              id="topology-tab-{{ loop.index0 }}"
              role="tab"
              aria-controls="topology-panel-{{ loop.index0 }}"
              aria-selected="{% if loop.first %}true{% else %}false{% endif %}"
            >
              {{ r.display_name }}
            </button>
            {% endfor %}
            <button
              type="button"
              class="tab-button"
              data-topology-tab
              data-target="topology-panel-comparison"
              id="topology-tab-comparison"
              role="tab"
              aria-controls="topology-panel-comparison"
              aria-selected="false"
            >
              All Topologies
            </button>
          </div>
        </div>
      </section>

      {% for r in results %}
      <article
        class="plot-card plot-card-dark topology-panel"
        data-highlight-mode="{{ r.interaction_mode }}"
        data-topology-panel="topology-panel-{{ loop.index0 }}"
        id="topology-panel-{{ loop.index0 }}"
        role="tabpanel"
        aria-labelledby="topology-tab-{{ loop.index0 }}"
        {% if not loop.first %}hidden{% endif %}
      >
        <div class="plot-card-head">
          <h2>{{ r.display_name }}</h2>
          <div class="eyebrow">{{ r.topology.scale }} | {{ r.topology.exchange_node_count }} exchange nodes</div>
          <div class="interaction-chip">Click a node to highlight neighbors. Scroll to zoom, drag to pan, and double-click to reset.</div>
        </div>

        <div class="plot-shell">
          <h3>Topology Figure</h3>
          <div class="plot-frame">{{ r.plot_html | safe }}</div>

          {% if r.traffic_plots %}
          <div class="traffic-grid">
            {% for traffic in r.traffic_plots %}
            <div class="traffic-panel">
              <h3>{{ traffic.title }}</h3>
              <div class="plot-frame">{{ traffic.plot_html | safe }}</div>
            </div>
            {% endfor %}
          </div>
          {% endif %}
        </div>

        <div class="detail-pane">
          <div class="detail-top-grid">
            <section class="section">
              <h3>Key Metrics</h3>
              <div class="metrics-grid">
                <div class="metric"><span class="k">Diameter</span><span class="v">{{ '%.0f'|format(r.structural_metrics.diameter) }}</span></div>
                <div class="metric"><span class="k">Average Hops</span><span class="v">{{ '%.2f'|format(r.structural_metrics.average_hops) }}</span></div>
                <div class="metric"><span class="k">Bisection Bandwidth</span><span class="v">{{ '%.1f'|format(r.structural_metrics.bisection_bandwidth_gbps) }} Gbps</span></div>
                <div class="metric"><span class="k">Bisection BW / SSU</span><span class="v">{{ '%.2f'|format(r.structural_metrics.bisection_bandwidth_gbps_per_ssu) }} Gbps</span></div>
                <div class="metric"><span class="k">Backend Links</span><span class="v">{{ r.topology.backend_link_count }}</span></div>
              </div>
            </section>

            <section class="section">
              <h3>Workload Setup</h3>
              <div class="stack">
                <div class="workload-panel">
                  <h4>Traffic Models</h4>
                  <div class="stack">
                    {% for workload in r.workload_descriptions %}
                    <div class="kv">
                      <span class="k">{{ workload.title }}</span>
                      <span class="v">{{ workload.description }}</span>
                    </div>
                    {% endfor %}
                  </div>
                </div>

                <div class="workload-panel">
                  <h4>Routing Modes</h4>
                  <div class="stack">
                    {% for routing_mode in r.routing_mode_descriptions %}
                    <div class="kv">
                      <span class="k">{{ routing_mode.mode }}</span>
                      <span class="v">{{ routing_mode.description }}</span>
                    </div>
                    {% endfor %}
                  </div>
                </div>

                {% if r.routing_diversity %}
                <div class="small-notes">{{ r.routing_diversity.summary }}</div>
                {% endif %}
              </div>
            </section>
          </div>

          <section class="section">
            <h3>Routing Comparison</h3>
            <div class="stack">
              {% if r.routing_comparison %}
                {% for section in r.routing_comparison.sections %}
                <div class="compact-table-panel">
                  <h4>{{ section.title }}</h4>
                  <div class="compact-table-wrap">
                    <table class="compact-table">
                      <thead>
                        <tr>
                          <th>Mode</th>
                          {% for column in r.routing_comparison.columns %}
                          <th>{{ column.label }}</th>
                          {% endfor %}
                        </tr>
                      </thead>
                      <tbody>
                        {% for row in section.rows %}
                        <tr>
                          <td>{{ row.mode }}</td>
                          {% for column in r.routing_comparison.columns %}
                            {% set value = row[column.key] %}
                            {% if column.key == 'per_ssu_throughput_gbps' %}
                            <td>{{ '%.2f'|format(value) }} Gbps</td>
                            {% elif column.key in ['completion_time_s', 'completion_time_p95_s'] %}
                            <td>{{ '%.4f'|format(value) }} s</td>
                            {% elif column.key == 'average_hops' %}
                            <td>{{ '%.2f'|format(value) }}</td>
                            {% elif column.key == 'max_link_utilization' %}
                            <td>{{ '%.2f'|format(value * 100) }}%</td>
                            {% else %}
                            <td>{{ '%.3f'|format(value) }}</td>
                            {% endif %}
                          {% endfor %}
                        </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                </div>
                {% endfor %}
              {% else %}
              <div class="compact-table-panel">
                <h4>{{ r.routing.mode }} Comparison</h4>
                <div class="compact-table-wrap">
                  <table class="compact-table">
                    <thead>
                      <tr>
                        <th>Workload</th>
                        <th>Per SSU Throughput</th>
                        <th>Completion Time</th>
                        <th>P95 Completion</th>
                        <th>Average Hops</th>
                        <th>Max Link Utilization</th>
                        <th>Link Utilization CV</th>
                      </tr>
                    </thead>
                    <tbody>
                      {% for workload in r.workload_metric_rows %}
                      <tr>
                        <td>{{ workload.display_name }}</td>
                        <td>{{ '%.2f'|format(workload.per_ssu_throughput_gbps) }} Gbps</td>
                        <td>{{ '%.4f'|format(workload.completion_time_s) }} s</td>
                        <td>{{ '%.4f'|format(workload.completion_time_p95_s) }} s</td>
                        <td>{{ '%.2f'|format(workload.average_hops) }}</td>
                        <td>{{ '%.2f'|format(workload.max_link_utilization * 100) }}%</td>
                        <td>{{ '%.3f'|format(workload.link_utilization_cv) }}</td>
                      </tr>
                      {% endfor %}
                    </tbody>
                  </table>
                </div>
              </div>
              {% endif %}
            </div>
          </section>
        </div>
      </article>
      {% endfor %}

      <article
        class="plot-card plot-card-dark topology-panel"
        data-topology-panel="topology-panel-comparison"
        id="topology-panel-comparison"
        role="tabpanel"
        aria-labelledby="topology-tab-comparison"
        hidden
      >
        <div class="plot-card-head">
          <h2>All Topology Comparison</h2>
          <div class="eyebrow">跨拓扑汇总：结构指标、A2A 与稀疏 M-to-N 通信结果</div>
        </div>
        <div class="plot-shell">
          <div class="comparison-grid">
            <div class="compact-table-panel">
              <h4>Structural Overview</h4>
              <div class="compact-table-wrap">
                <table class="compact-table">
                  <thead>
                    <tr>
                      <th>Topology</th>
                      <th>Diameter</th>
                      <th>Average Hops</th>
                      <th>SSUs</th>
                      <th>Unions</th>
                      <th>SSU-Union Links</th>
                      <th>Union-Union Links</th>
                      <th>Bisection BW</th>
                      <th>Bisection BW / SSU</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for r in results %}
                    <tr>
                      <td>{{ r.display_name }}</td>
                      <td>{{ '%.0f'|format(r.structural_metrics.diameter) }}</td>
                      <td>{{ '%.2f'|format(r.structural_metrics.average_hops) }}</td>
                      <td>{{ r.topology.ssu_count }}</td>
                      <td>{{ r.topology.union_count }}</td>
                      <td>{{ r.topology.internal_link_count }}</td>
                      <td>{{ r.topology.backend_link_count }}</td>
                      <td>{{ '%.1f'|format(r.structural_metrics.bisection_bandwidth_gbps) }} Gbps</td>
                      <td>{{ '%.2f'|format(r.structural_metrics.bisection_bandwidth_gbps_per_ssu) }} Gbps</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>

            <div class="compact-table-panel">
              <h4>A2A Comparison</h4>
              <div class="compact-table-wrap">
                <table class="compact-table">
                  <thead>
                    <tr>
                      <th>Topology</th>
                      <th>Per SSU Throughput</th>
                      <th>Completion Time</th>
                      <th>Average Hops</th>
                      <th>Max Link Utilization</th>
                      <th>Link Utilization CV</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for r in results %}
                    <tr>
                      <td>{{ r.display_name }}</td>
                      <td>{{ '%.2f'|format(r.communication_metrics['A2A'].per_ssu_throughput_gbps) }} Gbps</td>
                      <td>{{ '%.4f'|format(r.communication_metrics['A2A'].completion_time_s) }} s</td>
                      <td>{{ '%.2f'|format(r.communication_metrics['A2A'].average_hops) }}</td>
                      <td>{{ '%.2f'|format(r.communication_metrics['A2A'].max_link_utilization * 100) }}%</td>
                      <td>{{ '%.3f'|format(r.communication_metrics['A2A'].link_utilization_cv) }}</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>

            <div class="compact-table-panel">
              <h4>Sparse M-to-N Comparison</h4>
              <div class="compact-table-wrap">
                <table class="compact-table">
                  <thead>
                    <tr>
                      <th>Topology</th>
                      <th>Per SSU Throughput</th>
                      <th>P95 Completion</th>
                      <th>Average Hops</th>
                      <th>Max Link Utilization</th>
                      <th>Link Utilization CV</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for r in results %}
                    <tr>
                      <td>{{ r.display_name }}</td>
                      <td>{{ '%.2f'|format(r.communication_metrics['Sparse 1-to-N'].per_ssu_throughput_gbps) }} Gbps</td>
                      <td>{{ '%.4f'|format(r.communication_metrics['Sparse 1-to-N'].completion_time_p95_s) }} s</td>
                      <td>{{ '%.2f'|format(r.communication_metrics['Sparse 1-to-N'].average_hops) }}</td>
                      <td>{{ '%.2f'|format(r.communication_metrics['Sparse 1-to-N'].max_link_utilization * 100) }}%</td>
                      <td>{{ '%.3f'|format(r.communication_metrics['Sparse 1-to-N'].link_utilization_cv) }}</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>

            {% if comparison_summary %}
            <div class="compact-table-panel">
              <h4>简要分析</h4>
              <div class="stack">
                {% for item in comparison_summary %}
                <div class="kv">
                  <span class="k">{{ item.title }}</span>
                  <span class="v">{{ item.body }}</span>
                </div>
                {% endfor %}
              </div>
            </div>
            {% endif %}
          </div>
        </div>
      </article>
    </section>
  </div>

  <script>
    function registerTopologyHighlight() {
      return true;
    }
  </script>
  <script>
    (function() {
      function resizeVisiblePlots(panel) {
        if (!panel || !window.Plotly || !window.Plotly.Plots) return;
        window.requestAnimationFrame(function() {
          panel.querySelectorAll('.js-plotly-plot').forEach(function(plot) {
            window.Plotly.Plots.resize(plot);
          });
        });
      }

      function activateTopologyPanel(targetId) {
        const buttons = document.querySelectorAll('[data-topology-tab]');
        const panels = document.querySelectorAll('[data-topology-panel]');
        buttons.forEach(function(button) {
          const isActive = button.getAttribute('data-target') === targetId;
          button.classList.toggle('is-active', isActive);
          button.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
        panels.forEach(function(panel) {
          const isActive = panel.getAttribute('data-topology-panel') === targetId;
          panel.hidden = !isActive;
          if (isActive) {
            resizeVisiblePlots(panel);
          }
        });
      }

      document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('[data-topology-tab]').forEach(function(button) {
          button.addEventListener('click', function() {
            activateTopologyPanel(button.getAttribute('data-target'));
          });
        });

        const firstPanel = document.querySelector('[data-topology-panel]:not([hidden])');
        resizeVisiblePlots(firstPanel);
      });
    })();
  </script>
  {% for r in results %}
  <script>
    {{ r.interaction_script | safe }}
  </script>
  {% endfor %}
</body>
</html>
